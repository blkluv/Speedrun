# ── RPC URLs ──────────────────────────────────────────────────────────────
# Used by Foundry (forge/cast) and the sync-abi Makefile target.
BASE_MAINNET_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ── Deploy key ────────────────────────────────────────────────────────────
# ONLY used for the initial `forge script` deployment of Speedrun.sol.
# After that, every B20 operation is signed by the connected browser wallet.
# NEVER commit this. NEVER pass to the Next.js app.
PRIVATE_KEY=0x...

# ── BaseScan verification ─────────────────────────────────────────────────
BASESCAN_API_KEY=

# ── Frontend (Next.js) ────────────────────────────────────────────────────
# WalletConnect project ID — get one free at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Deployed Speedrun contract address (set after forge deploy, used in README examples)
NEXT_PUBLIC_SPEEDRUN_ADDRESS=
